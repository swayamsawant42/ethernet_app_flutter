							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"date\": \"2025-11-08\",\n    \"distance_km\": 7.5,\n    \"vehicle_type\": \"OWN_VEHICLE\",\n    \"started_at\": \"2025-11-08T04:30:00.000Z\",\n    \"ended_at\": \"2025-11-08T05:05:00.000Z\",\n    \"route\": {\n      \"vehicle\": {\n        \"name\": \"Honda Activa\",\n        \"number\": \"MH12 XY 5678\",\n        \"type\": \"BIKE\"\n      },\n      \"stops\": [\n        {\n          \"name\": \"Office\",\n          \"address\": \"Bibwewadi, Pune\",\n          \"start_time\": \"2025-11-08T04:30:00.000Z\",\n          \"position\": { \"lat\": 18.4736, \"lng\": 73.8684 }\n        },\n        {\n          \"name\": \"Client Visit\",\n          \"address\": \"Market Yard, Pune\",\n          \"start_time\": \"2025-11-08T04:45:00.000Z\",\n          \"end_time\": \"2025-11-08T05:05:00.000Z\",\n          \"position\": { \"lat\": 18.5016, \"lng\": 73.8741 }\n        }\n      ],\n      \"path\": [\n        { \"lat\": 18.4736, \"lng\": 73.8684 },\n        { \"lat\": 18.4832, \"lng\": 73.8699 },\n        { \"lat\": 18.4937, \"lng\": 73.8724 },\n        { \"lat\": 18.5016, \"lng\": 73.8741 }\n      ]\n    }\n  }"
						},
						"url": {
							"raw": "{{baseUrl}}/travelTracker",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"travelTracker"
							]
						},
						"description": "Add or update the authenticated executive's travel record for a specific date. Payout is automatically calculated at ₹3 per km when travelling in your own vehicle.\n\n**Auth:** Bearer token required. `user_id` is derived from the token.\n\n**Required fields:**\n- date (YYYY-MM-DD)\n- distance_km (float ≥ 0)\n- vehicle_type (Own vehicle | Colleague | Company vehicle)\n\n**Optional fields:**\n- route (string or JSON object describing the journey)\n- started_at / ended_at (ISO datetime strings)\n- auto_ended (boolean flag set when system ends the trip automatically)"
					},
					"response": []
				},
